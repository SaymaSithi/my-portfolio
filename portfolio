    <style>
        /* Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #000;
            color: #fff;
            scroll-behavior: smooth;
            overflow-x: hidden;
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            line-height: 1.6;
        }

        /* Navbar */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 20px 60px;
            z-index: 999;
            background: transparent;
            transition: background 0.3s ease;
        }

        header.scrolled {
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(10px);
        }

        .nav-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Mobile menu toggle */
        .menu-toggle {
            display: none;
            background: transparent;
            border: 0;
            color: #fff;
            font-size: 22px;
            width: 44px;
            height: 44px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 1001;
        }

        .menu-toggle:focus-visible {
            outline: none;
            box-shadow: 0 0 0 4px rgba(240, 201, 106, 0.16);
            border-radius: 8px;
        }

        .logo {
            font-size: 26px;
            font-weight: 700;
            color: #fff;
        }

        .logo span {
            color: #f0c96a;
        }

        .nav-menu {
            display: flex;
            list-style: none;
        }

        .nav-menu li {
            margin-left: 30px;
        }

        .nav-menu a {
            color: #fff;
            text-decoration: none;
            transition: 0.3s;
            font-weight: 500;
            font-size: 16px;
        }

        .nav-menu a:hover {
            color: #f0c96a;
        }

        /* Hero Section */
        .hero-section {
            height: 100vh;
            width: 100%;
            background: linear-gradient(120deg, #00140a 0%, #07210f 40%, #024719 70%, #44b16e 100%);
            background-size: 300% 300%;
            animation: gradientShift 16s ease-in-out infinite alternate;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
            padding: 40px 20px;
        }

        .welcome-text {
            color: #f0c96a;
            font-size: 18px;
            margin-bottom: 10px;
        }

        .creative-heading, .hero-text, .welcome-text {
            text-shadow: 0 6px 18px rgba(0,0,0,0.6);
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; filter: hue-rotate(0deg); }
            50% { background-position: 50% 70%; filter: hue-rotate(6deg); }
            100% { background-position: 100% 50%; filter: hue-rotate(-6deg); }
        }

        /* Respect user's reduced motion preference */
        @media (prefers-reduced-motion: reduce) {
            .hero-section { animation: none; background-size: 100% 100%; }
        }

        .hero-section::before {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: radial-gradient(1200px 500px at 10% 20%, rgba(240,201,106,0.06), transparent 18%),
                        radial-gradient(800px 300px at 90% 80%, rgba(68,177,110,0.03), transparent 18%);
            mix-blend-mode: overlay;
            z-index: 0;
        }
        .hero-section > div { position: relative; z-index: 1; }

        .creative-heading {
            margin-top: 10px;
            line-height: 1.2;
            font-size: clamp(28px, 6vw, 50px);
        }

        #typewriter {
            color: #f0c96a;
            display: inline-block;
        }

        .hero-text {
            max-width: 550px;
            margin: 20px auto 30px;
            opacity: 0.9;
            line-height: 1.6;
            font-size: clamp(14px, 2.3vw, 18px);
        }

        .hero-section > div { max-width: 980px; padding: 0 20px; }

        .social-icons {
            margin-top: 30px;
        }

        .social-icons a {
            color: white;
            font-size: 22px;
            margin: 0 10px;
            padding: 12px;
            border: 1px solid #ffffff2c;
            border-radius: 50%;
            transition: 0.3s;
            display: inline-flex;
            width: 50px;
            height: 50px;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }

        .social-icons a:hover {
            background: #f0c96a;
            color: #000;
            transform: translateY(-5px);
        }

        .scroll-down {
            position: absolute;
            bottom: 38px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            z-index: 1;
        }

        .mouse {
            width: 34px;
            height: 56px;
            border: 2px solid rgba(255,255,255,0.95);
            border-radius: 20px;
            position: relative;
            display: inline-block;
            box-shadow: 0 6px 18px rgba(0,0,0,0.35);
            background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(0,0,0,0));
        }

        .mouse::after {
            content: '';
            width: 7px;
            height: 7px;
            background: #fff;
            border-radius: 50%;
            position: absolute;
            top: 8px;
            left: 50%;
            transform: translateX(-50%);
            animation: scroll 1.6s ease-in-out infinite;
            box-shadow: 0 6px 12px rgba(0,0,0,0.45);
        }

        @keyframes scroll {
            0% {
                opacity: 0;
                top: 8px;
                transform: translateX(-50%) scale(0.9);
            }
            35% {
                opacity: 1;
                top: 16px;
                transform: translateX(-50%) scale(1);
            }
            70% {
                opacity: 0.6;
                top: 24px;
                transform: translateX(-50%) scale(0.95);
            }
            100% {
                opacity: 0;
                top: 32px;
                transform: translateX(-50%) scale(0.9);
            }
        }

        /* Respect prefers-reduced-motion */
        @media (prefers-reduced-motion: reduce) {
            .mouse::after { animation: none; opacity: 1; top: 16px; }
        }

        /* Transparent Sections */
        #about, #services, #portfolio, #testimonial, #contact {
            padding: 100px 80px;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            position: relative;
        }

        /* Add subtle background pattern for visual interest */
        #about::before, #services::before, #portfolio::before, #testimonial::before, #contact::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(202, 149, 14, 0.03) 0%, transparent 20%),
                radial-gradient(circle at 85% 30%, rgba(68, 177, 110, 0.03) 0%, transparent 20%);
            z-index: -1;
        }

        .about-container {
            display: flex;
            align-items: center;
            gap: 50px;
        }

        .about-image {
            flex: 1;
            text-align: center;
        }

        .about-image img {
            width: 100%;
            max-width: 400px;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .about-text {
            flex: 1;
        }

        .section-title {
            font-size: 40px;
            margin-bottom: 20px;
            color: #f0c96a;
        }

        .about-text p {
            line-height: 1.8;
            opacity: .9;
            margin-bottom: 20px;
            font-size: 16px;
        }

        .skills-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 30px;
        }

        .skill-item {
            background: rgba(26, 26, 26, 0.7);
            padding: 15px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            transition: 0.3s;
            backdrop-filter: blur(5px);
        }

        .skill-item:hover {
            background: rgba(34, 34, 34, 0.8);
            transform: translateY(-5px);
        }

        .skill-item i {
            color: #f0c96a;
            font-size: 20px;
            margin-right: 15px;
        }

        /* Services */
        .services-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .service-box {
            background: rgba(26, 26, 26, 0.7);
            padding: 30px;
            border-radius: 10px;
            transition: .3s;
            text-align: center;
            backdrop-filter: blur(5px);
        }

        .service-box:hover {
            transform: translateY(-10px);
            background: rgba(34, 34, 34, 0.8);
        }

        .service-box i {
            font-size: 40px;
            color: #f0c96a;
            margin-bottom: 15px;
        }

        .service-box h3 {
            margin-bottom: 15px;
            font-size: 22px;
        }

        .service-box p {
            font-size: 16px;
        }

        /* Portfolio */
       .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
}

.project {
    height: 250px;
    background: rgba(34, 34, 34, 0.7);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    backdrop-filter: blur(5px);
}

.project::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(240, 201, 106, 0.7));
    opacity: 0;
    transition: opacity 0.3s ease;
}

.project:hover::after {
    opacity: 1;
}

.project-title {
    position: absolute;
    bottom: 20px;
    left: 20px;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.3s ease;
    font-weight: 600;
    color: #fff;
}

.project:hover .project-title {
    opacity: 1;
}

        /* Testimonials - FIXED */
        .testimonial-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .testimonial-header h2 {
            font-size: 40px;
            margin-bottom: 10px;
            color: #f0c96a;
        }

        .testimonial-header p {
            max-width: 600px;
            margin: 0 auto;
            font-size: 16px;
            opacity: 0.8;
        }

        .testimonials-container {
            max-width: 900px;
            width: 100%;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
            border-radius: 15px;
            background: rgba(26, 26, 26, 0.8);
            backdrop-filter: blur(10px);
            padding: 50px 40px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        }

        .testimonial-slide {
            display: none;
            animation: fadeIn 0.8s ease;
            text-align: center;
        }

        .testimonial-slide.active {
            display: block;
        }

        .testimonial-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #f0c96a;
            margin: 0 auto 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        .stars {
            color: #f0c96a;
            font-size: 20px;
            margin-bottom: 15px;
            letter-spacing: 3px;
        }

        .testimonial-text {
            font-size: 18px;
            line-height: 1.7;
            color: #fff;
            margin-bottom: 20px;
            font-style: italic;
            padding: 0 20px;
        }

        .testimonial-author {
            font-size: 22px;
            font-weight: 600;
            color: #f0c96a;
            margin-bottom: 5px;
        }

        .testimonial-role {
            font-size: 16px;
            color: #ccc;
            margin-bottom: 10px;
        }

        .testimonial-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(240, 201, 106, 0.9);
            color: #000;
            border: none;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            font-size: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        .testimonial-btn:hover {
            background: #f0c96a;
            transform: translateY(-50%) scale(1.1);
        }

        .prev-btn {
            left: 20px;
        }

        .next-btn {
            right: 20px;
        }

        .testimonial-indicators {
            display: flex;
            justify-content: center;
            margin-top: 30px;
            gap: 10px;
        }

        .indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .indicator.active {
            background: #f0c96a;
            transform: scale(1.2);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Make sure anchor targets aren't hidden behind the fixed header */
        #home, #about, #services, #portfolio, #testimonial, #contact, footer {
            scroll-margin-top: 100px;
        }

        /* Contact */
        .contact-form {
            max-width: 600px;
            margin: 0 auto;
        }

        input,
        textarea {
            width: 100%;
            padding: 12px;
            margin: 12px 0;
            border-radius: 6px;
            border: 1px solid #333;
            background: rgba(17, 17, 17, 0.7);
            color: #fff;
            font-size: 16px;
            backdrop-filter: blur(5px);
        }

        input:focus,
        textarea:focus {
            outline: none;
            border-color: #f0c96a;
        }

        /* Button styles */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 12px 25px;
            background: #f0c96a;
            border: none;
            cursor: pointer;
            border-radius: 6px;
            font-weight: bold;
            transition: transform 0.18s ease, background 0.18s ease;
            color: #000;
            font-size: 16px;
            text-decoration: none;
        }

        .btn:hover { 
            background: #d8b259; 
            transform: translateY(-3px); 
        }

        /* Accessible focus style (visible when keyboard navigation used) */
        .btn:focus-visible {
            outline: none;
            box-shadow: 0 0 0 4px rgba(240, 201, 106, 0.18);
        }

        /* Footer */
        footer {
            background: rgba(0,0,0,0.45);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            padding: 60px 0 30px;
            border-top: 1px solid rgba(255,255,255,0.04);
            position: relative;
            z-index: 1;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
        }

        .footer-column h3 {
            font-size: 22px;
            margin-bottom: 20px;
            color: #f0c96a;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 10px;
        }

        .footer-links a {
            color: #ccc;
            text-decoration: none;
            transition: color 0.3s;
            font-size: 16px;
        }

        .footer-links a:hover {
            color: #f0c96a;
        }

        .footer-social {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

        .footer-social a {
            color: white;
            font-size: 20px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(26, 26, 26, 0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.3s;
            text-decoration: none;
            backdrop-filter: blur(5px);
        }

        .footer-social a:hover {
            background: #f0c96a;
            color: #000;
            transform: translateY(-3px);
        }

        footer, .footer-links a, .copyright p {
            color: rgba(255,255,255,0.88);
        }

        .copyright {
            text-align: center;
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #333;
            color: #999;
            font-size: 14px;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .about-container {
                flex-direction: column;
            }
            
            .about-image, .about-text {
                width: 100%;
            }
            
            .footer-container {
                grid-template-columns: 1fr 1fr;
            }
        }

        /* Slightly smaller scroll margin on very small screens */
        @media (max-width: 480px) {
            #home, #about, #services, #portfolio, #testimonial, #contact, footer {
                scroll-margin-top: 76px;
            }
        }

        @media (max-width: 768px) {
            header {
                padding: 15px 20px;
            }

            .nav-menu {
                display: none;
                position: absolute;
                top: calc(100% + 8px);
                right: 20px;
                background: rgba(15,15,15,0.96);
                padding: 12px 18px;
                border-radius: 10px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.6);
                width: auto;
                flex-direction: column;
                gap: 12px;
            }

            .menu-toggle { 
                display: inline-flex; 
            }

            /* show nav when open */
            .nav-menu.open { 
                display: flex; 
                z-index: 1001; 
            }

            .creative-heading {
                font-size: 36px;
            }

            .hero-section { min-height: 72vh; padding-top: 80px; padding-bottom: 40px; }

            .hero-section > div { padding: 0 14px; }

            #about, #services, #portfolio, #testimonial, #contact {
                padding: 60px 20px;
            }

            .services-container, .portfolio-grid {
                grid-template-columns: 1fr;
            }
            
            .skills-container {
                grid-template-columns: 1fr;
            }
            
            .footer-container {
                grid-template-columns: 1fr;
            }
            
            /* Testimonial responsive adjustments */
            .testimonials-container {
                padding: 30px 20px;
            }
            
            .testimonial-btn {
                width: 40px;
                height: 40px;
                font-size: 18px;
                top: 40%;
            }
            
            .testimonial-text {
                font-size: 16px;
                padding: 0 10px;
            }
            
            .prev-btn {
                left: 10px;
            }
            
            .next-btn {
                right: 10px;
            }
        }

        /* hide testimonial nav on very small phones and small layout tweaks */
        @media (max-width: 480px) {
            header { 
                padding: 12px 14px; 
            }
            #about, #services, #portfolio, #testimonial, #contact { 
                padding: 40px 14px; 
            }
            /* make mobile nav full width inside small margins */
            .nav-menu { 
                left: 12px; 
                right: 12px; 
                top: calc(100% + 6px); 
            }
            .creative-heading { 
                font-size: clamp(22px, 10vw, 36px); 
            }
            .social-icons a { 
                width: 44px; 
                height: 44px; 
            }
            /* hide decorative mouse on very small devices */
            .scroll-down { display: none; }
            .testimonial-btn { 
                display: none; 
            }
            
            .testimonials-container {
                padding: 25px 15px;
            }
            
            .testimonial-img {
                width: 80px;
                height: 80px;
            }
            
            .testimonial-text {
                font-size: 15px;
            }
        }
    </style>
</head>

