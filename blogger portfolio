    (function() {
        var navLinks = document.querySelectorAll('.nav-links a, .btn-portfolio[href^="#"]');
        for (var i = 0; i < navLinks.length; i++) {
            navLinks[i].addEventListener('click', function(e) {
                var hash = this.getAttribute('href');
                if (hash && hash !== '#' && hash.indexOf('#') === 0) {
                    var target = document.querySelector(hash);
                    if (target) {
                        e.preventDefault();
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                }
            });
        }
        var contactBtn = document.getElementById('demoContactBtn');
        if (contactBtn) {
            contactBtn.addEventListener('click', function(e) {
                e.preventDefault();
                alert("Send an email to your@email.com to start a project!");
            });
        }
        var sections = document.querySelectorAll('#home, #projects, #skills, #services, #contact');
        var navItems = document.querySelectorAll('.nav-links a');
        function highlightNav() {
            var scrollPos = window.scrollY + 130;
            for (var i = 0; i < sections.length; i++) {
                var section = sections[i];
                if (section) {
                    var top = section.offsetTop;
                    var bottom = top + section.offsetHeight;
                    if (scrollPos >= top && scrollPos < bottom) {
                        var id = section.getAttribute('id');
                        for (var j = 0; j < navItems.length; j++) {
                            navItems[j].classList.remove('active-nav');
                            if (navItems[j].getAttribute('href') === '#' + id) {
                                navItems[j].classList.add('active-nav');
                            }
                        }
                    }
                }
            }
        }
        window.addEventListener('scroll', highlightNav);
        window.addEventListener('load', highlightNav);
    })();
    // ]]>
